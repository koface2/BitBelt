{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Expo Web (dev)",
      "type": "shell",
      "command": "npx expo start --web --port 8081",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build Web (static)",
      "type": "shell",
      "command": "npx expo export --platform web",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
