# BitBelt — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to source control.

# ── Frontend (Expo / Thirdweb) ────────────────────────────────────────────────

# Thirdweb project client ID (https://thirdweb.com/dashboard)
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=59d60bc1bd6a153d7dfc7792e1549c6e

# ERC-4337 Paymaster URL for gasless / sponsored transactions on Base
PAYMASTER_URL=https://bundler.thirdweb.com/v2/your_paymaster_url_here

# Deployed SBT contract address (fill in after running the deploy script)
SBT_CONTRACT_ADDRESS=0x958dBb461e039902113e65518eC64D3379fDF2e2

# ── Contract Deployment (Foundry) ─────────────────────────────────────────────

# Wallet that will be granted DEFAULT_ADMIN_ROLE and INSTRUCTOR_ROLE on deploy.
# Use a hardware wallet or multisig (Safe) address in production.
DEPLOYER_ADDRESS=0x56edD8E0b4eA14ca259f313291B9468553e2Ae94

# Private key of the deployer wallet — used only by Foundry broadcast scripts.
# WARNING: never share or commit this value.
PRIVATE_KEY=0x7c35c9dbdf2a13e8ce3533c45c32fcc02746d12ca896cda425678c214e819d0c


# Base Sepolia RPC (free tier: https://www.alchemy.com or https://infura.io)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification (https://basescan.org/myapikey)
BASESCAN_API_KEY=1MW57MVE7MHCV177CI15ISWFVV3C8WYEFT

# Smart account address to grant DEFAULT_ADMIN_ROLE + INSTRUCTOR_ROLE
GRANT_TARGET=0xc91D6b060f50cf9C69F946bACc6FEF595f1f1906

