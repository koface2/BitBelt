# BitBelt Environment Variables
# Copy this file to .env and fill in your values

# Thirdweb Client ID (get from https://thirdweb.com/dashboard)
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here

# Network: "mainnet" for Base Mainnet, anything else uses Base Sepolia (testnet)
EXPO_PUBLIC_NETWORK=testnet

# Smart Account Factory Address (deployed on Base)
# This is used for Account Abstraction / gasless transactions
EXPO_PUBLIC_ACCOUNT_FACTORY_ADDRESS=your_account_factory_address_here
